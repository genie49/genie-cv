{
  "name": "genie-cv",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:client": "bun --filter '@genie-cv/client' dev",
    "dev:server": "bun --filter '@genie-cv/server' dev",
    "dev": "bun run dev:client & bun run dev:server",
    "build": "bun --filter '*' build",
    "embed": "bun run scripts/embed.ts"
  }
}
